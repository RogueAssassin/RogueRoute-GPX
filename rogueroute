#!/usr/bin/env bash
set -euo pipefail
ROOT="$(cd "$(dirname "${BASH_SOURCE[0]}")" && pwd)"
ENV="$ROOT/.env"
COMPOSE=(docker compose --env-file "$ENV" -f "$ROOT/compose.yaml")

fail() { echo "[ERROR] $*" >&2; exit 1; }
[[ -f "$ENV" ]] || { cp "$ROOT/.env.example" "$ENV"; chmod 600 "$ENV"; }
command -v docker >/dev/null || fail "Docker Engine is not installed."
docker compose version >/dev/null || fail "Docker Compose plugin is not installed."

get_env() {
  local key="$1" fallback="${2:-}" value
  value="$(grep -E "^${key}=" "$ENV" | tail -n1 | cut -d= -f2- || true)"
  printf '%s\n' "${value:-$fallback}"
}

set_env() {
  local key="$1" value="$2"
  if grep -qE "^${key}=" "$ENV"; then
    sed -i "s|^${key}=.*|${key}=${value}|" "$ENV"
  else
    printf '%s=%s\n' "$key" "$value" >> "$ENV"
  fi
}

ensure_runtime_secrets() {
  if [[ -z "$(get_env NEXT_SERVER_ACTIONS_ENCRYPTION_KEY)" ]]; then
    command -v openssl >/dev/null || fail "OpenSSL is required to generate runtime secrets."
  fi
  [[ -n "$(get_env NEXT_SERVER_ACTIONS_ENCRYPTION_KEY)" ]] ||
    set_env NEXT_SERVER_ACTIONS_ENCRYPTION_KEY "$(openssl rand -base64 32)"
  set_env OSRM_SWITCH_ENABLED true
  set_env OSRM_MANAGER_URL http://manager:9090
  set_env OSRM_MANAGER_TOKEN_FILE /run/rogueroute-secrets/manager-token
  [[ -n "$(get_env OSRM_SWITCH_COOLDOWN_SECONDS)" ]] ||
    set_env OSRM_SWITCH_COOLDOWN_SECONDS 60
  sed -i '/^OSRM_MANAGER_TOKEN=/d; /^OSRM_SWITCH_ACCESS_KEY=/d' "$ENV"
  chmod 600 "$ENV" 2>/dev/null || true
}

requested_command="${1:-help}"
[[ "$requested_command" == permissions ]] || ensure_runtime_secrets

ensure_writable_runtime() {
  [[ -w "$ROOT" && -w "$ENV" ]] ||
    fail "Deployment files are not writable by $(id -un). Run once: sudo ./rogueroute permissions"
}

repository_version() {
  local tag version
  [[ -r "$ROOT/VERSION" ]] || fail "Missing VERSION file. This deployment must be a complete Git checkout."
  tag="$(tr -d '[:space:]' < "$ROOT/VERSION")"
  version="${tag#v}"
  [[ "$tag" == "v$version" && "$version" =~ ^[0-9]+\.[0-9]+\.[0-9]+$ ]] ||
    fail "Invalid VERSION value: $tag"
  printf '%s\n' "$version"
}

sync_repository_version() {
  local version current
  version="$(repository_version)"
  current="$(get_env ROGUEROUTE_VERSION)"
  if [[ "$current" != "$version" ]]; then
    set_env ROGUEROUTE_VERSION "$version"
    echo "[INFO] Container version updated from ${current:-unset} to $version."
  fi
}

verify_graph() {
  local dir graph failures=0
  dir="$(get_env OSRM_DATA_DIR /mnt/h/osrm)"
  graph="$(get_env OSRM_GRAPH australia-latest.osrm)"
  [[ -r "$dir/$graph.mldgr" ]] || { echo "[ERROR] Missing prepared graph: $dir/$graph.mldgr" >&2; failures=$((failures + 1)); }
  [[ -r "$dir/$graph.partition" ]] || { echo "[ERROR] Missing graph partition: $dir/$graph.partition" >&2; failures=$((failures + 1)); }
  [[ -r "$dir/$graph.cell_metrics" ]] || { echo "[ERROR] Missing graph cell metrics: $dir/$graph.cell_metrics" >&2; failures=$((failures + 1)); }
  if (( failures > 0 )); then
    echo "[INFO] Prepare the selected region with: ./rogueroute osm prepare REGION" >&2
    return 1
  fi
}

container_health() {
  docker inspect --format '{{if .State.Health}}{{.State.Health.Status}}{{else}}{{.State.Status}}{{end}}' "$1" 2>/dev/null || printf 'missing\n'
}

wait_for_healthy() {
  local timeout deadline state web manager osrm
  timeout="$(get_env ROGUEROUTE_STARTUP_TIMEOUT_SECONDS 600)"
  [[ "$timeout" =~ ^[0-9]+$ ]] && (( timeout >= 30 )) || fail "ROGUEROUTE_STARTUP_TIMEOUT_SECONDS must be at least 30."
  deadline=$((SECONDS + timeout))
  echo "[INFO] Waiting up to ${timeout}s for Web, Manager and OSRM health checks."
  while (( SECONDS < deadline )); do
    web="$(container_health rogueroute-gpx-web)"
    manager="$(container_health rogueroute-gpx-manager)"
    osrm="$(container_health rogueroute-gpx-osrm)"
    if [[ "$web" == healthy && "$manager" == healthy && "$osrm" == healthy ]]; then
      echo "[OK] Web, Manager and OSRM are healthy."
      return 0
    fi
    for state in "$web" "$manager" "$osrm"; do
      if [[ "$state" == unhealthy || "$state" == exited || "$state" == dead ]]; then
        "${COMPOSE[@]}" ps >&2 || true
        "${COMPOSE[@]}" logs --tail=100 web manager osrm >&2 || true
        fail "A RogueRoute service became $state before startup completed."
      fi
    done
    sleep 2
  done
  "${COMPOSE[@]}" ps >&2 || true
  "${COMPOSE[@]}" logs --tail=100 web manager osrm >&2 || true
  fail "RogueRoute did not become healthy within ${timeout}s."
}

show_help() {
  cat <<'HELP'
RogueRoute GPX administration

Usage: ./rogueroute COMMAND [OPTIONS]

Container commands:
  start                 Verify the active graph, pull images and start the stack
  stop                  Stop RogueRoute containers without deleting map data
  restart               Pull and recreate the web, manager and OSRM containers
  update                Apply VERSION from Git, pull that image and recreate services
  permissions           Repair checkout, environment and map-data ownership
  status                Show container state and health
  logs [SERVICE]        Follow all logs, or only web, manager or osrm
  doctor                Check Docker, configuration, graph files and manager health
  config                Print the effective non-secret RogueRoute configuration
  version               Show the configured application and image version

Map commands:
  osm list              List every supported downloadable region
  osm status            Show downloaded/prepared state for all regions
  osm path              Show the configured OSRM data directory
  osm download REGION…  Download or resume one or more Geofabrik PBF files
  osm download-missing  Download/resume every missing catalog PBF
  osm prepare REGION    Build and select an OSRM MLD graph in OSRM_DATA_DIR
  osm prepare-downloaded Prepare every downloaded but incomplete graph
  osm verify REGION     Verify the required MLD files for a region
  osm switch REGION     Select a prepared graph and recreate only OSRM
  osm help              Show detailed map command help
HELP
}

doctor() {
  local failures=0 dir graph
  dir="$(get_env OSRM_DATA_DIR /mnt/h/osrm)"
  graph="$(get_env OSRM_GRAPH australia-latest.osrm)"
  echo "RogueRoute: v$(get_env ROGUEROUTE_VERSION unknown)"
  echo "Deployment: $ROOT"
  echo "Map data: $dir"
  echo "Active graph: $graph"
  "${COMPOSE[@]}" config -q || failures=$((failures + 1))
  verify_graph || failures=$((failures + 1))
  if "${COMPOSE[@]}" ps --status running manager | grep -q rogueroute-gpx-manager; then
    "${COMPOSE[@]}" exec -T manager wget -qO- http://127.0.0.1:9090/health >/dev/null || failures=$((failures + 1))
  else
    echo "[WARN] Manager is not running. Start the stack to enable website switching."
  fi
  if "${COMPOSE[@]}" ps --status running web | grep -q rogueroute-gpx-web; then
    "${COMPOSE[@]}" exec -T web wget -qO- http://127.0.0.1:9080/api/health >/dev/null || failures=$((failures + 1))
    "${COMPOSE[@]}" exec -T web wget -qO- http://127.0.0.1:9080/api/health/osrm >/dev/null || failures=$((failures + 1))
  else
    echo "[WARN] Web is not running. Start the stack to run HTTP readiness checks."
  fi
  (( failures == 0 )) || fail "$failures diagnostic check(s) failed."
  echo "[OK] Configuration and active graph checks passed."
}

cmd="${1:-help}"; shift || true
case "$cmd" in
  start)
    verify_graph || fail "The active OSRM graph is incomplete."
    "${COMPOSE[@]}" pull
    "${COMPOSE[@]}" up -d --remove-orphans
    wait_for_healthy
    "${COMPOSE[@]}" ps ;;
  stop) "${COMPOSE[@]}" down ;;
  restart)
    verify_graph || fail "The active OSRM graph is incomplete."
    "${COMPOSE[@]}" pull
    "${COMPOSE[@]}" up -d --force-recreate --remove-orphans
    wait_for_healthy
    "${COMPOSE[@]}" ps ;;
  update)
    ensure_writable_runtime
    sync_repository_version
    verify_graph || fail "The active OSRM graph is incomplete."
    "${COMPOSE[@]}" pull
    "${COMPOSE[@]}" up -d --remove-orphans
    wait_for_healthy
    "${COMPOSE[@]}" images
    echo "[OK] RogueRoute GPX v$(repository_version) is applied." ;;
  permissions)
    [[ $EUID -eq 0 ]] || fail "Run: sudo ./rogueroute permissions"
    owner="${SUDO_USER:-root}"
    group="$(id -gn "$owner")"
    dir="$(get_env OSRM_DATA_DIR /mnt/h/osrm)"
    chown -R "$owner:$group" "$ROOT" "$dir"
    chmod 600 "$ENV"
    chmod +x "$ROOT/install.sh" "$ROOT/rogueroute" "$ROOT/scripts/osm.sh"
    echo "[OK] $owner owns the deployment and map-data directories."
    echo "[INFO] If Docker still requires sudo, add $owner to the docker group and log in again." ;;
  status) "${COMPOSE[@]}" ps ;;
  logs) "${COMPOSE[@]}" logs --tail=200 -f "$@" ;;
  doctor) doctor ;;
  config)
    printf '%-32s %s\n' \
      ROGUEROUTE_VERSION "$(get_env ROGUEROUTE_VERSION unknown)" \
      ROGUEROUTE_IMAGE "$(get_env ROGUEROUTE_IMAGE ghcr.io/rogueassassin/rogueroute-gpx)" \
      HOST_PORT "$(get_env HOST_PORT 9080)" \
      OSRM_DATA_DIR "$(get_env OSRM_DATA_DIR /mnt/h/osrm)" \
      OSRM_ACTIVE_REGION "$(get_env OSRM_ACTIVE_REGION australia)" \
      OSRM_GRAPH "$(get_env OSRM_GRAPH australia-latest.osrm)" \
      OSRM_IMAGE "$(get_env OSRM_IMAGE ghcr.io/project-osrm/osrm-backend:v26.7.3)" \
      OSRM_SWITCH_ENABLED "$(get_env OSRM_SWITCH_ENABLED true)" \
      OSRM_SNAP_RADIUS_METERS "$(get_env OSRM_SNAP_RADIUS_METERS 250)" \
      OSRM_SNAP_MAX_RADIUS_METERS "$(get_env OSRM_SNAP_MAX_RADIUS_METERS 5000)" \
      GPX_MAX_TRACK_POINTS "$(get_env GPX_MAX_TRACK_POINTS 1000)" ;;
  version) echo "RogueRoute GPX v$(get_env ROGUEROUTE_VERSION unknown)" ;;
  osm) exec "$ROOT/scripts/osm.sh" "$@" ;;
  help|-h|--help) show_help ;;
  *) fail "Unknown command: $cmd" ;;
esac

ROGUEROUTE_VERSION=12.5.1
ROGUEROUTE_IMAGE=ghcr.io/rogueassassin/rogueroute-gpx
HOST_PORT=9080

OSRM_IMAGE=ghcr.io/project-osrm/osrm-backend:v26.7.3
OSRM_HOST_PORT=5000
OSRM_DATA_DIR=/mnt/h/osrm
OSRM_ACTIVE_REGION=australia
OSRM_GRAPH=australia-latest.osrm
OSRM_PROFILE=foot
OSRM_SNAP_RADIUS_METERS=250
OSRM_SNAP_MAX_RADIUS_METERS=5000
OSRM_MAX_PARALLEL_LEGS=6
OSRM_SWITCH_ENABLED=true
OSRM_MANAGER_URL=http://manager:9090
OSRM_MANAGER_TOKEN_FILE=/run/rogueroute-secrets/manager-token
OSRM_SWITCH_COOLDOWN_SECONDS=60
ROGUEROUTE_STARTUP_TIMEOUT_SECONDS=600

GPX_MAX_TRACK_POINTS=1000
GPX_SIMPLIFY_TOLERANCE_METERS=2.5
ROUTE_CACHE_LIMIT=100
NEXT_SERVER_ACTIONS_ENCRYPTION_KEY=

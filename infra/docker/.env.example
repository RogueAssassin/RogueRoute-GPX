HOST_PORT=9080
PORT=9080
NEXT_PUBLIC_APP_NAME=RogueRoute-GPX
ROGUEROUTE_VERSION=v11

# Stable Server Action key. deploy.sh/first-run.sh auto-generate this in infra/docker/.env.
# Keep the value stable across rebuilds to prevent stale browser tabs from calling missing action IDs.
NEXT_SERVER_ACTIONS_ENCRYPTION_KEY=

# Routing: OSRM is the OSRM default. Use direct only for emergency/testing.
ROUTER_MODE=osrm
# Internal Docker URL used by gpx-web. Keep this as the Compose service name.
# Container/log name remains rogueroute-osrm, but app traffic should use osrm.
OSRM_URL=http://osrm:5000
OSRM_PROFILE=foot
# First snap attempt and the strict maximum adaptive search radius.
OSRM_SNAP_RADIUS_METERS=250
OSRM_SNAP_MAX_RADIUS_METERS=5000
OSRM_MAX_PARALLEL_LEGS=6
ROUTE_CACHE_LIMIT=100
# Automatic GPX export keeps walking/path geometry but removes redundant points.
# Automatic defaults to a 2.5m tolerance and aims for no more than 1000 track points.
GPX_MAX_TRACK_POINTS=1000
GPX_SIMPLIFY_TOLERANCE_METERS=2.5
# Fully scan new/recovered PBF files with osmium before accepting them.
OSM_VERIFY_FULL=true
OSM_DOWNLOAD_RETRIES=5
OSRM_DATA_DIR=/mnt/h/osrm
OSRM_PBF=australia-latest.osm.pbf
OSRM_GRAPH=australia-latest.osrm
OSRM_HOST_PORT=5000
OSRM_THREADS=2
OSRM_SAFE_THREADS=1

# Optional display tile API keys belong in the frontend only. They are not used for routing.
NEXT_PUBLIC_MAP_PROVIDER=
NEXT_PUBLIC_MAP_API_KEY=

# Region switching: one OSRM container, many prepared regional graphs.
OSRM_ACTIVE_REGION=australia
OSRM_SWITCH_ENABLED=true
OSRM_SWITCH_SCRIPT=/host/rogueroute/switch-osrm-region.sh

# Downloaded/available PBF catalogue. download-osm.sh keeps these current.
OSRM_REGION_AUSTRALIA=australia-latest.osm.pbf
OSRM_REGION_NEW_ZEALAND=new-zealand-latest.osm.pbf
OSRM_REGION_JAPAN=japan-latest.osm.pbf
OSRM_REGION_CHINA=china-latest.osm.pbf
OSRM_REGION_SOUTH_KOREA=south-korea-latest.osm.pbf
OSRM_REGION_TAIWAN=taiwan-latest.osm.pbf
OSRM_REGION_SINGAPORE_MALAYSIA_BRUNEI=malaysia-singapore-brunei-latest.osm.pbf
OSRM_REGION_INDONESIA=indonesia-latest.osm.pbf
OSRM_REGION_INDIA=india-latest.osm.pbf
OSRM_REGION_US=us-latest.osm.pbf
OSRM_REGION_HAWAII=hawaii-latest.osm.pbf
OSRM_REGION_CANADA=canada-latest.osm.pbf
OSRM_REGION_MEXICO=mexico-latest.osm.pbf
OSRM_REGION_CENTRAL_AMERICA=central-america-latest.osm.pbf
OSRM_REGION_SOUTH_AMERICA=south-america-latest.osm.pbf
OSRM_REGION_EUROPE=europe-latest.osm.pbf
OSRM_REGION_UK_IRELAND=britain-and-ireland-latest.osm.pbf
OSRM_REGION_GERMANY=germany-latest.osm.pbf
OSRM_REGION_FRANCE=france-latest.osm.pbf
OSRM_REGION_SPAIN=spain-latest.osm.pbf
OSRM_REGION_ITALY=italy-latest.osm.pbf
OSRM_REGION_NETHERLANDS=netherlands-latest.osm.pbf
OSRM_FORCE_SAFE_BUILDS=true
# Optional hard cap for OSRM preprocessing containers, e.g. 48g or 96g. Leave blank to use Docker defaults.
OSRM_DOCKER_MEMORY=

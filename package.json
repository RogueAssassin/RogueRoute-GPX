{
  "name": "gpx-route-generator",
  "version": "12.2.0",
  "private": true,
  "packageManager": "pnpm@11.12.0",
  "engines": {
    "node": "24.18.0",
    "pnpm": "11.12.0"
  },
  "scripts": {
    "dev": "pnpm --filter @rogue/gpx-web dev",
    "build": "pnpm -r build",
    "start": "pnpm --filter @rogue/gpx-web start",
    "console": "pnpm --filter @rogue/gpx-console start",
    "version:check": "bash scripts/version.sh check",
    "version:set": "bash scripts/version.sh set",
    "typecheck": "pnpm --filter @rogue/gpx-core build && pnpm -r typecheck",
    "test": "pnpm -r --if-present test"
  },
  "devDependencies": {
    "@types/node": "^24.3.0",
    "typescript": "^6.0.3"
  }
}

HOST_PORT=9080
OSRM_HOST_PORT=5000

# Prebuilt RogueRoute GPX web container. No Node.js or pnpm build is required.
ROGUEROUTE_IMAGE=ghcr.io/rogueassassin/rogueroute-gpx
ROGUEROUTE_IMAGE_TAG=v12
NEXT_PUBLIC_APP_VERSION=v12
NEXT_SERVER_ACTIONS_ENCRYPTION_KEY=

ROUTER_MODE=osrm
OSRM_URL=http://osrm:5000
OSRM_PROFILE=foot
OSRM_DATA_DIR=/mnt/h/osrm
OSRM_PBF=australia-latest.osm.pbf
OSRM_GRAPH=australia-latest.osrm
OSRM_ACTIVE_REGION=australia

# Try the nearby network first, then progressively expand to this strict cap.
OSRM_SNAP_RADIUS_METERS=250
OSRM_SNAP_MAX_RADIUS_METERS=5000
OSRM_MAX_PARALLEL_LEGS=6

ROUTE_CACHE_LIMIT=100
GPX_MAX_TRACK_POINTS=1000
GPX_SIMPLIFY_TOLERANCE_METERS=2.5

# OSRM remains a separate container because regional graph files are large.
OSRM_IMAGE=osrm/osrm-backend:latest
OSRM_SWITCH_ENABLED=false
